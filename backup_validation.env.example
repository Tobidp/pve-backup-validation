# ==============================================================================
# backup_validation.env — environment variables and secrets for backup_validation.sh
#
# This file is sourced by the script at runtime and OVERRIDES the defaults
# defined inside the script itself.
#
# Install:
#   cp backup_validation.env /root/backup_validation.env
#   chmod 600 /root/backup_validation.env       # contains secrets
#   (or point to another path via the BACKUP_VALIDATION_ENV environment variable)
#
# Save with LF (Unix) line endings. CRLF is tolerated, but prefer LF.
# Uncomment only what you want to override; everything else uses the script default.
# ==============================================================================

# ── PBS / PVE ──────────────────────────────────────────────────────────────
#PBS_STORAGE="pbs"                # PBS storage name in PVE
#RESTORE_STORAGE="local-lvm"      # Local destination storage for the temporary restore
#ISOLATED_BRIDGE="vmbr99"         # Isolated bridge (no route to production)
#TEMP_VMID_PREFIX="9"             # Temp VMID = prefix + original VMID (e.g. 675 -> 9675)

# ── Timeouts (seconds) ─────────────────────────────────────────────────────
#BOOT_TIMEOUT=180                 # Wait for boot + guest-agent
#SERVICE_TIMEOUT=60               # Wait for the service to respond
#RESTORE_TIMEOUT=3600             # Maximum restore timeout
#GUEST_EXEC_TIMEOUT=120           # Max time for a command via guest-agent

# ── Files ──────────────────────────────────────────────────────────────────
#CONFIG_FILE="/root/backup_validation.conf"      # List of VMs to test
#LOG_BASE="/var/log/backup_validation"           # Logs root
#LOCKFILE="/var/lock/backup_validation.lock"     # Single-run lock
#TEMP_VM_TAG="backup-validation-temp"            # Tag applied to the throwaway test VM

# ── Telegram (secrets) ─────────────────────────────────────────────────────
TELEGRAM_TOKEN=""                 # SET: bot token (e.g. 123456:ABC-DEF...)
TELEGRAM_CHAT_ID=""               # SET: destination chat_id
TELEGRAM_SILENT_ON_SUCCESS=true   # true = success messages without sound
